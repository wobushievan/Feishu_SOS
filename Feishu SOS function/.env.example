# Feishu
# FEISHU_APP_ID: Feishu self-built app ID. Required by server startup.
FEISHU_APP_ID=
# FEISHU_APP_SECRET: Feishu self-built app secret. Required by server startup.
FEISHU_APP_SECRET=

# App URLs
# APP_BASE_URL: Base URL used to build feedback H5 links when request context cannot provide it.
APP_BASE_URL=
# PLATFORM_API_URL: Base URL for platform user API calls in getUserEmailsByIds().
PLATFORM_API_URL=
# CLIENT_BASE_PATH: Frontend router basename injected at build/runtime.
CLIENT_BASE_PATH=/

# Server
# NODE_ENV: Runtime mode used by server bootstrap and build/start scripts.
NODE_ENV=development
# SERVER_HOST: Nest server listen host.
SERVER_HOST=localhost
# SERVER_PORT: Nest server listen port.
SERVER_PORT=3000

# Local dev script
# LOG_DIR: scripts/dev.js log output directory.
LOG_DIR=logs
# MAX_RESTART_COUNT: scripts/dev.js max restart attempts per managed process.
MAX_RESTART_COUNT=10
# RESTART_DELAY: scripts/dev.js initial restart backoff in seconds.
RESTART_DELAY=2
# CLIENT_DEV_PORT: Vite dev server port tracked by scripts/dev.js for cleanup/supervision.
CLIENT_DEV_PORT=8080

# Database
# No repo-local database env vars are currently read by this codebase.
# Database access is injected by @lark-apaas/fullstack-nestjs-core via DRIZZLE_DATABASE.
